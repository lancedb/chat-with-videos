# AWS Credentials (for accessing the LanceDB Enterprise S3 bucket via Lance blob API)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-2
S3_BUCKET=yt-agents

# LanceDB Enterprise
LANCEDB_URI=db://your-database
LANCEDB_API_KEY=your-lancedb-api-key
LANCEDB_REGION=us-east-1
LANCEDB_HOST_OVERRIDE=https://example.hostoverride.io

# Lance dataset S3 path (for blob API access — points to LanceDB Enterprise's S3 bucket)
# This is the underlying S3 path where LanceDB Enterprise stores the videos.lance table
LANCE_DATASET_S3_PATH=s3://your-lancedb-bucket/your-database/videos.lance
LANCE_DATASET_S3_REGION=us-east-2

OPENAI_API_KEY=your-openai-api-key

CORS_ORIGIN=your-vercel-app.vercel.app
